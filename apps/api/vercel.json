{
  "version": 2,
  "builds": [
    {
      "src": "index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.ts"
    }
  ],
  "github": {
    "productionBranch": "main"
  },
  "headers": [
    {
      "source": "/assets/(.*)\\.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript; charset=utf-8" }]
    },
    {
      "source": "/assets/(.*)\\.css",
      "headers": [{ "key": "Content-Type", "value": "text/css; charset=utf-8" }]
    }
  ],
  "rewrites": [
    { "source": "/ascend/(.*)", "destination": "/ascend/apps/web/dist/index.html" },
    { "source": "/((?!api).*)", "destination": "/ascend/apps/web/dist/index.html" },
    { "source": "/api/(.*)", "destination": "/api/dist/index.js" }
  ]
}
