# Local dev — override only if MFEs are not on localhost
VITE_REMOTE_HOST=localhost
VITE_API_HOST=localhost

# Production: full remoteEntry.js URL for each deployed MFE
# Set these in Vercel project settings (or .env.production.local for preview builds)
VITE_MFE_DASHBOARD_URL=https://your-mfe-dashboard.vercel.app/remoteEntry.js
VITE_MFE_POSITION_SIZING_URL=https://your-mfe-position-sizing.vercel.app/remoteEntry.js
VITE_MFE_USER_MANAGEMENT_URL=https://your-mfe-user-management.vercel.app/remoteEntry.js
VITE_MFE_SUPER_ADMIN_URL=https://your-mfe-super-admin.vercel.app/remoteEntry.js

# Allowed CORS origin for the API (set to the deployed shell URL)
FRONTEND_URL=https://your-shell.vercel.app
